{
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": [
    "javascript",
    "typescript",
    "svelte",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "markdown"
  ],
  "eslint.workingDirectories": [
    "app/frontend"
  ],
  "svelte.enable-ts-plugin": true
}
